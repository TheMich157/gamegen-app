<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ManifestApp.Pages.OnboardingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Disabled"
    mc:Ignorable="d">

    <Grid Background="{StaticResource GameGenHeroSurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top progress strip -->
        <StackPanel
            Grid.Row="0"
            Padding="32,28,32,12"
            Spacing="6">
            <TextBlock
                x:Name="StepIndicator"
                FontSize="11" FontWeight="SemiBold"
                CharacterSpacing="220"
                Foreground="{StaticResource GameGenAccentGradientBrush}"
                Text="STEP 1 OF 3" />
            <ProgressBar
                x:Name="StepProgress"
                Maximum="2"
                Value="0" />
        </StackPanel>

        <ScrollViewer
            Grid.Row="1"
            Padding="32,12,32,16"
            VerticalScrollBarVisibility="Auto">
            <Grid MinHeight="320">

                <!-- ──────── Welcome ──────── -->
                <StackPanel
                    x:Name="WelcomePanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Loaded="WelcomePanel_Loaded"
                    Opacity="0"
                    Spacing="18">
                    <StackPanel.RenderTransform>
                        <CompositeTransform x:Name="WelcomeTransform" TranslateY="18" />
                    </StackPanel.RenderTransform>

                    <!-- Logo plate with gradient halo -->
                    <Grid Width="120" Height="120" HorizontalAlignment="Center">
                        <Ellipse Width="120" Height="120" Opacity="0.6">
                            <Ellipse.Fill>
                                <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5"
                                                     RadiusX="0.5" RadiusY="0.5">
                                    <GradientStop Color="#A06E45FF" Offset="0" />
                                    <GradientStop Color="#003B6BFF" Offset="1" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Border Width="92" Height="92" CornerRadius="20"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Background="{StaticResource GameGenAccentGradientBrush}">
                            <Image Source="ms-appx:///Assets/GameGenAppLogo.png"
                                   Stretch="UniformToFill" Margin="6" />
                        </Border>
                    </Grid>

                    <!-- Status pill -->
                    <Border CornerRadius="999" Padding="12,5,16,5"
                            BorderThickness="1"
                            BorderBrush="{StaticResource GameGenSubtleAccentStrokeBrush}"
                            Background="{StaticResource GameGenSubtleAccentBackgroundBrush}"
                            HorizontalAlignment="Center">
                        <TextBlock Text="FIRST-RUN SETUP"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="#FFB8C8FF"
                                   CharacterSpacing="160" />
                    </Border>

                    <StackPanel Spacing="2" HorizontalAlignment="Center">
                        <TextBlock Text="GAMEGEN"
                                   FontSize="13" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="#809FB7FF"
                                   CharacterSpacing="240" />
                        <TextBlock FontSize="48" FontWeight="Bold"
                                   LineHeight="54" CharacterSpacing="-15"
                                   HorizontalAlignment="Center"
                                   Text="WELCOME"
                                   Foreground="{StaticResource GameGenAccentGradientBrush}" />
                    </StackPanel>

                    <TextBlock
                        MaxWidth="560"
                        HorizontalAlignment="Center"
                        Foreground="{StaticResource GameGenSecondaryTextBrush}"
                        FontSize="14" LineHeight="22"
                        Text="Search your Steam library, generate manifests with GameGen, and install them in a few taps. First, point the app at your Steam folder and add your GameGen API key."
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <!-- ──────── Steam path ──────── -->
                <StackPanel
                    x:Name="SteamPanel"
                    Spacing="14"
                    MaxWidth="640"
                    HorizontalAlignment="Center"
                    Visibility="Collapsed">

                    <StackPanel Spacing="2">
                        <TextBlock Text="STEAM PATH"
                                   FontSize="11" FontWeight="SemiBold"
                                   CharacterSpacing="220"
                                   Foreground="{StaticResource GameGenAccentGradientBrush}" />
                        <TextBlock FontSize="36" FontWeight="Bold"
                                   LineHeight="42" CharacterSpacing="-10"
                                   Text="Where is Steam installed?"
                                   Foreground="#FFEDEDF5" />
                    </StackPanel>

                    <TextBlock
                        Foreground="{StaticResource GameGenSecondaryTextBrush}"
                        FontSize="13" LineHeight="20"
                        Text="We need the folder that contains steam.exe (plugin and depot paths are filled in automatically)."
                        TextWrapping="WrapWholeWords" />

                    <TextBox
                        x:Name="SteamPathBox"
                        AutomationProperties.HelpText="Folder that contains steam.exe"
                        Header="Steam install folder"
                        PlaceholderText="Example: C:\Program Files (x86)\Steam"
                        TextChanged="SteamPathBox_TextChanged" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="BrowseSteam_Click" Content="Browse folder…" />
                        <Button Click="AutoDetectSteam_Click" Content="Auto-detect from Windows" />
                    </StackPanel>

                    <TextBlock
                        x:Name="SteamValidation"
                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                        TextWrapping="WrapWholeWords"
                        Visibility="Collapsed" />

                    <Border CornerRadius="12" Padding="16,12,16,12"
                            Margin="0,8,0,0"
                            BorderThickness="1"
                            BorderBrush="{StaticResource GameGenSubtleAccentStrokeBrush}"
                            Background="{StaticResource GameGenSubtleAccentBackgroundBrush}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="WE WILL USE"
                                       FontSize="11" FontWeight="SemiBold"
                                       CharacterSpacing="200"
                                       Foreground="{StaticResource GameGenAccentGradientBrush}" />
                            <TextBlock
                                x:Name="PluginPreview"
                                Foreground="{StaticResource GameGenSecondaryTextBrush}"
                                FontSize="12"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                x:Name="DepotPreview"
                                Foreground="{StaticResource GameGenSecondaryTextBrush}"
                                FontSize="12"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ──────── API key ──────── -->
                <StackPanel
                    x:Name="ApiPanel"
                    Spacing="14"
                    MaxWidth="640"
                    HorizontalAlignment="Center"
                    Visibility="Collapsed">

                    <StackPanel Spacing="2">
                        <TextBlock Text="API KEY"
                                   FontSize="11" FontWeight="SemiBold"
                                   CharacterSpacing="220"
                                   Foreground="{StaticResource GameGenAccentGradientBrush}" />
                        <TextBlock FontSize="36" FontWeight="Bold"
                                   LineHeight="42" CharacterSpacing="-10"
                                   Text="GameGen API key"
                                   Foreground="#FFEDEDF5" />
                    </StackPanel>

                    <TextBlock
                        Foreground="{StaticResource GameGenSecondaryTextBrush}"
                        FontSize="13" LineHeight="20"
                        Text="Paste the key from your GameGen dashboard. It is stored only in Windows Credential Locker on this PC."
                        TextWrapping="WrapWholeWords" />

                    <PasswordBox
                        x:Name="ApiKeyBox"
                        Header="Your GameGen API key"
                        PlaceholderText="Paste your key" />

                    <TextBlock
                        x:Name="ApiValidation"
                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                        TextWrapping="WrapWholeWords"
                        Visibility="Collapsed" />
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Footer nav -->
        <Border
            Grid.Row="2"
            BorderThickness="0,1,0,0"
            BorderBrush="{StaticResource GameGenHeroStrokeBrush}">
            <Grid Padding="24,14,24,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="BackButton"
                    Grid.Column="1"
                    Margin="0,0,8,0"
                    Padding="20,9,20,9"
                    Click="Back_Click"
                    Content="Back"
                    IsEnabled="False" />

                <Button
                    x:Name="NextButton"
                    Grid.Column="2"
                    Padding="20,9,20,9"
                    Click="Next_Click"
                    Content="Next"
                    Style="{StaticResource AccentButtonStyle}" />
            </Grid>
        </Border>
    </Grid>
</Page>
