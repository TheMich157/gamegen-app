<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ManifestApp.Pages.OnboardingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Disabled"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            Padding="32,28,32,8"
            Spacing="4">
            <TextBlock
                x:Name="StepIndicator"
                Opacity="0.65"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="Step 1 of 3" />
            <ProgressBar
                x:Name="StepProgress"
                Maximum="2"
                Value="0" />
        </StackPanel>

        <ScrollViewer
            Grid.Row="1"
            Padding="32,8,32,16"
            VerticalScrollBarVisibility="Auto">
            <Grid MinHeight="320">
                <!-- Welcome -->
                <StackPanel
                    x:Name="WelcomePanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Loaded="WelcomePanel_Loaded"
                    Opacity="0"
                    Spacing="16">
                    <StackPanel.RenderTransform>
                        <CompositeTransform x:Name="WelcomeTransform" TranslateY="18" />
                    </StackPanel.RenderTransform>

                    <Image
                        Width="96"
                        Height="96"
                        HorizontalAlignment="Center"
                        Source="ms-appx:///Assets/GameGenAppLogo.png" />

                    <TextBlock
                        HorizontalAlignment="Center"
                        Style="{StaticResource TitleTextBlockStyle}"
                        Text="Welcome to GameGen App"
                        TextAlignment="Center" />

                    <TextBlock
                        MaxWidth="520"
                        HorizontalAlignment="Center"
                        Opacity="0.78"
                        Text="Search your Steam library, generate manifests with GameGen, and install them in a few taps. First, point the app at your Steam folder and add your GameGen API key."
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <!-- Steam -->
                <StackPanel
                    x:Name="SteamPanel"
                    Spacing="12"
                    Visibility="Collapsed">
                    <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Where is Steam installed?" />
                    <TextBlock
                        Opacity="0.72"
                        Text="We need the folder that contains steam.exe (plugin and depot paths are filled in automatically)."
                        TextWrapping="WrapWholeWords" />

                    <TextBox
                        x:Name="SteamPathBox"
                        AutomationProperties.HelpText="Folder that contains steam.exe"
                        Header="Steam install folder"
                        PlaceholderText="Example: C:\Program Files (x86)\Steam"
                        TextChanged="SteamPathBox_TextChanged" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="BrowseSteam_Click" Content="Browse folder…" />
                        <Button Click="AutoDetectSteam_Click" Content="Auto-detect from Windows" />
                    </StackPanel>

                    <TextBlock
                        x:Name="SteamValidation"
                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                        TextWrapping="WrapWholeWords"
                        Visibility="Collapsed" />

                    <TextBlock
                        Margin="0,16,0,0"
                        FontWeight="SemiBold"
                        Text="We will use" />
                    <TextBlock
                        x:Name="PluginPreview"
                        Opacity="0.78"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        x:Name="DepotPreview"
                        Opacity="0.78"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <!-- API -->
                <StackPanel
                    x:Name="ApiPanel"
                    Spacing="12"
                    Visibility="Collapsed">
                    <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="GameGen API key" />
                    <TextBlock
                        Opacity="0.72"
                        Text="Paste the key from your GameGen dashboard. It is stored only in Windows Credential Locker on this PC."
                        TextWrapping="WrapWholeWords" />

                    <PasswordBox
                        x:Name="ApiKeyBox"
                        Header="Your GameGen API key"
                        PlaceholderText="Paste your key" />

                    <TextBlock
                        x:Name="ApiValidation"
                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                        TextWrapping="WrapWholeWords"
                        Visibility="Collapsed" />
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Grid
            Grid.Row="2"
            Padding="24,12,24,24"
            Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                x:Name="BackButton"
                Grid.Column="1"
                Margin="0,0,8,0"
                Click="Back_Click"
                Content="Back"
                IsEnabled="False" />

            <Button
                x:Name="NextButton"
                Grid.Column="2"
                Click="Next_Click"
                Content="Next"
                Style="{StaticResource AccentButtonStyle}" />
        </Grid>
    </Grid>
</Page>
