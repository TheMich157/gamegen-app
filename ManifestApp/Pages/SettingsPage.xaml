<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ManifestApp.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="{StaticResource ManifestInsetPadding}" Spacing="20">

            <!-- ──────── HERO ──────── -->
            <Border CornerRadius="20" Padding="32,26,32,26"
                    BorderThickness="1"
                    BorderBrush="{StaticResource GameGenHeroStrokeBrush}"
                    Background="{StaticResource GameGenHeroSurfaceBrush}">
                <StackPanel Spacing="14">

                    <!-- Status pill -->
                    <Border CornerRadius="999" Padding="12,5,16,5"
                            BorderThickness="1"
                            BorderBrush="{StaticResource GameGenSubtleAccentStrokeBrush}"
                            Background="{StaticResource GameGenSubtleAccentBackgroundBrush}"
                            HorizontalAlignment="Left">
                        <TextBlock Text="CONTROL CENTER"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="#FFB8C8FF"
                                   CharacterSpacing="160" />
                    </Border>

                    <StackPanel Spacing="2">
                        <TextBlock Text="GAMEGEN"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#809FB7FF"
                                   CharacterSpacing="240" />
                        <TextBlock FontSize="44" FontWeight="Bold"
                                   LineHeight="50" CharacterSpacing="-15"
                                   Text="PREFERENCES"
                                   Foreground="{StaticResource GameGenAccentGradientBrush}" />
                    </StackPanel>

                    <TextBlock Foreground="{StaticResource GameGenSecondaryTextBrush}"
                               FontSize="13" LineHeight="20"
                               MaxWidth="640" HorizontalAlignment="Left"
                               TextWrapping="WrapWholeWords"
                               Text="Tune appearance, point GameGen at your Steam folders, store your API key, and stay current with updates." />
                </StackPanel>
            </Border>

            <!-- ──────── APPEARANCE ──────── -->
            <Border CornerRadius="14" Padding="20,18,20,18"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="2">
                        <TextBlock Text="APPEARANCE"
                                   FontSize="11" FontWeight="SemiBold"
                                   CharacterSpacing="220"
                                   Foreground="{StaticResource GameGenAccentGradientBrush}" />
                        <TextBlock FontSize="22" FontWeight="SemiBold" Text="Theme &amp; integrations" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <ToggleSwitch
                            x:Name="DarkThemeToggle"
                            Header="Dark theme"
                            OffContent="Following Windows"
                            OnContent="Always dark"
                            Toggled="DarkThemeToggle_Toggled" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="When dark theme is off, the app picks light or dark from Windows. Turning it on forces dark Fluent styling everywhere."
                            TextWrapping="WrapWholeWords"
                            Margin="0,0,0,4" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <ToggleSwitch
                            x:Name="DiscordPresenceToggle"
                            Header="Discord Rich Presence"
                            OffContent="Shown in Discord"
                            OnContent="Hidden"
                            Toggled="DiscordPresenceToggle_Toggled" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Requires the Discord desktop app. When hidden, GameGen stops updating your Discord status."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <ComboBox
                            x:Name="VideoStartupCombo"
                            Header="Game details videos"
                            SelectionChanged="VideoStartupCombo_SelectionChanged">
                            <ComboBoxItem Tag="muted" Content="Start muted" />
                            <ComboBoxItem Tag="paused" Content="Start paused" />
                            <ComboBoxItem Tag="sound" Content="Autoplay with sound" />
                        </ComboBox>
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Controls trailer playback when a game details page opens."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <ToggleSwitch
                            x:Name="AutoInstallOnlineFixToggle"
                            Header="Auto-install Steam game and online fix"
                            OffContent="Manual"
                            OnContent="Automatic"
                            Toggled="AutoInstallOnlineFixToggle_Toggled" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Automatically triggers the Steam download after generating a manifest, waits for it to finish, and installs the matching online fix zip directly into the game folder."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ──────── STEAM PATHS ──────── -->
            <Border CornerRadius="14" Padding="20,18,20,18"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <StackPanel Spacing="2">
                        <TextBlock Text="STEAM PATHS"
                                   FontSize="11" FontWeight="SemiBold"
                                   CharacterSpacing="220"
                                   Foreground="{StaticResource GameGenAccentGradientBrush}" />
                        <TextBlock FontSize="22" FontWeight="SemiBold" Text="Where GameGen drops manifests" />
                    </StackPanel>

                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Steam paths default from the registry. Override them here if installs are unusual or inaccessible."
                        TextWrapping="WrapWholeWords" />

                    <TextBox
                        x:Name="SteamPathBox"
                        Header="Steam install folder"
                        AutomationProperties.HelpText="Folder that contains steam.exe"
                        PlaceholderText="Example: C:\Program Files (x86)\Steam" />
                    <Button Click="BrowseSteam_Click" Content="Browse folder..." />

                    <TextBox
                        x:Name="PluginPathBox"
                        Header="stplug-in folder"
                        AutomationProperties.HelpText=".lua scripts are deployed here."
                        PlaceholderText="Example: ...\Steam\config\stplug-in" />
                    <Button Click="BrowsePlugin_Click" Content="Browse folder..." />

                    <TextBox
                        x:Name="DepotPathBox"
                        Header="depotcache folder"
                        AutomationProperties.HelpText=".manifest files are deployed here."
                        PlaceholderText="Example: ...\Steam\config\depotcache" />
                    <Button Click="BrowseDepot_Click" Content="Browse folder..." />

                    <Button Click="ResetPathsFromSteam_Click"
                            Content="Reset plugin + depot folders from Steam path" />

                    <TextBox
                        x:Name="SteamToolsPathBox"
                        Header="SteamTools.exe (optional override)"
                        PlaceholderText="Defaults to Steam install folder lookup" />
                    <Button Click="BrowseSteamTools_Click" Content="Browse SteamTools.exe..." />

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4,0,4" />

                    <Button Click="SaveSettings_Click"
                            Style="{StaticResource AccentButtonStyle}"
                            Content="Save Steam settings" />

                    <TextBlock
                        x:Name="SaveSettingsStatus"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="WrapWholeWords"
                        Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- ──────── GAMEGEN API ──────── -->
            <Border CornerRadius="14" Padding="20,18,20,18"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <StackPanel Spacing="2">
                        <TextBlock Text="GAMEGEN API"
                                   FontSize="11" FontWeight="SemiBold"
                                   CharacterSpacing="220"
                                   Foreground="{StaticResource GameGenAccentGradientBrush}" />
                        <TextBlock FontSize="22" FontWeight="SemiBold" Text="Authorize manifest downloads" />
                    </StackPanel>

                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Enter your GameGen API key from gamegen.lol (your dashboard). Downloads will not succeed until it is pasted and saved here."
                        TextWrapping="WrapWholeWords" />

                    <PasswordBox
                        x:Name="ApiKeyBox"
                        Header="Your GameGen API key"
                        PlaceholderText="Paste key, then tap Save API key securely" />

                    <Button Click="SaveGameGenSettings_Click"
                            Content="Save API key"
                            Style="{StaticResource AccentButtonStyle}" />

                    <TextBlock FontSize="12"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               TextWrapping="WrapWholeWords"
                               Text="Clears password field after saving. Leave password empty to keep the current stored key." />

                    <TextBlock
                        x:Name="ApiKeyStatus"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <!-- ──────── ABOUT ──────── -->
            <StackPanel Spacing="2" Margin="0,16,0,0">
                <TextBlock Text="ABOUT"
                           FontSize="11" FontWeight="SemiBold"
                           CharacterSpacing="220"
                           Foreground="{StaticResource GameGenAccentGradientBrush}" />
                <TextBlock FontSize="22" FontWeight="SemiBold" Text="Build &amp; updates" />
            </StackPanel>

            <Border CornerRadius="14" Padding="18,14,18,14"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="VERSION"
                                   FontSize="11" FontWeight="SemiBold"
                                   CharacterSpacing="200"
                                   Foreground="{StaticResource GameGenMutedTextBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock
                            x:Name="VersionText"
                            VerticalAlignment="Center"
                            FontSize="16" FontWeight="SemiBold"
                            Foreground="{StaticResource GameGenAccentGradientBrush}" />
                    </StackPanel>

                    <InfoBar
                        x:Name="UpdateInfoBar"
                        IsClosable="True"
                        IsOpen="False"
                        Severity="Informational" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="CheckUpdatesButton"
                                Click="CheckUpdates_Click"
                                Content="Check for updates" />

                        <Button x:Name="InstallUpdateButton"
                                Click="InstallUpdate_Click"
                                Content="Install update"
                                Style="{StaticResource AccentButtonStyle}"
                                Visibility="Collapsed" />
                    </StackPanel>

                    <ProgressBar
                        x:Name="UpdateProgressBar"
                        Maximum="100"
                        Visibility="Collapsed"
                        Margin="0,4,0,0" />

                    <TextBlock
                        x:Name="UpdateProgressText"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Visibility="Collapsed" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
