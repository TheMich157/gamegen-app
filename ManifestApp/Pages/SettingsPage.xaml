<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ManifestApp.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24,16,24,32" Spacing="12">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="GameGen App — Settings" />

            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Appearance" />

            <ToggleSwitch
                x:Name="DarkThemeToggle"
                Header="Dark theme"
                OffContent="Following Windows"
                OnContent="Always dark"
                Toggled="DarkThemeToggle_Toggled" />

            <TextBlock
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="When dark theme is off, the app picks light or dark from Windows. Turning it on forces dark Fluent styling everywhere."
                TextWrapping="WrapWholeWords" />

            <ToggleSwitch
                x:Name="DiscordPresenceToggle"
                Header="Discord Rich Presence"
                OffContent="Shown in Discord"
                OnContent="Hidden"
                Toggled="DiscordPresenceToggle_Toggled" />

            <TextBlock
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Requires the Discord desktop app. When hidden, GameGen stops updating your Discord status."
                TextWrapping="WrapWholeWords" />

            <MenuFlyoutSeparator Margin="0,16,0,8" />

            <TextBlock
                Opacity="0.72"
                Text="Steam paths default from the registry. Override them here if installs are unusual or inaccessible."
                TextWrapping="WrapWholeWords" />

            <TextBox
                x:Name="SteamPathBox"
                Header="Steam install folder"
                AutomationProperties.HelpText="Folder that contains steam.exe"
                PlaceholderText="Example: C:\Program Files (x86)\Steam" />

            <Button
                Margin="0,0,0,8"
                Click="BrowseSteam_Click"
                Content="Browse folder..." />

            <TextBox
                x:Name="PluginPathBox"
                Header="stplug-in folder"
                AutomationProperties.HelpText=".lua scripts are deployed here."
                PlaceholderText="Example: ...\Steam\config\stplug-in" />

            <Button Margin="0,0,0,8" Click="BrowsePlugin_Click" Content="Browse folder..." />

            <TextBox
                x:Name="DepotPathBox"
                Header="depotcache folder"
                AutomationProperties.HelpText=".manifest files are deployed here."
                PlaceholderText="Example: ...\Steam\config\depotcache" />

            <Button Margin="0,0,0,8" Click="BrowseDepot_Click" Content="Browse folder..." />

            <Button
                Margin="0,8,0,8"
                Click="ResetPathsFromSteam_Click"
                Content="Reset plugin + depot folders from Steam path" />

            <TextBox
                x:Name="SteamToolsPathBox"
                Header="SteamTools.exe (optional override)"
                PlaceholderText="Defaults to Steam install folder lookup" />

            <Button Margin="0,0,0,24" Click="BrowseSteamTools_Click" Content="Browse SteamTools.exe..." />

            <Button Click="SaveSettings_Click" Style="{StaticResource AccentButtonStyle}" Content="Save Steam settings" />

            <TextBlock
                x:Name="SaveSettingsStatus"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="WrapWholeWords"
                Visibility="Collapsed" />

            <MenuFlyoutSeparator Margin="0,16,0,16" />

            <TextBlock FontSize="20" FontWeight="SemiBold" Text="GameGen API" />

            <TextBlock
                Opacity="0.78"
                Text="Enter your GameGen API key from gamegen.lol (your dashboard). Downloads will not succeed until it is pasted and saved here."
                TextWrapping="WrapWholeWords" />

            <PasswordBox
                x:Name="ApiKeyBox"
                Header="Your GameGen API key"
                PlaceholderText="Paste key, then tap Save API key securely" />

            <Button Margin="0,8,0,0" Click="SaveGameGenSettings_Click"
                    Content="Save API key" />

            <TextBlock Margin="0,8,0,0" FontSize="12" Opacity="0.7"
                       TextWrapping="WrapWholeWords"
                       Text="Clears password field after saving. Leave password empty to keep the current stored key." />

            <TextBlock
                x:Name="ApiKeyStatus"
                Opacity="0.78"
                TextWrapping="WrapWholeWords"
                Margin="0,8,0,0" />

            <MenuFlyoutSeparator Margin="0,16,0,16" />

            <!-- ── About ───────────────────────────────────────────────────── -->
            <TextBlock FontSize="20" FontWeight="SemiBold" Text="About" />

            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock VerticalAlignment="Center" Text="Version" />
                <TextBlock
                    x:Name="VersionText"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold" />
            </StackPanel>

            <InfoBar
                x:Name="UpdateInfoBar"
                IsClosable="True"
                IsOpen="False"
                Severity="Informational" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button
                    x:Name="CheckUpdatesButton"
                    Click="CheckUpdates_Click"
                    Content="Check for updates" />

                <Button
                    x:Name="InstallUpdateButton"
                    Click="InstallUpdate_Click"
                    Content="Install update"
                    Style="{StaticResource AccentButtonStyle}"
                    Visibility="Collapsed" />
            </StackPanel>

            <ProgressBar
                x:Name="UpdateProgressBar"
                Maximum="100"
                Visibility="Collapsed"
                Margin="0,4,0,0" />

            <TextBlock
                x:Name="UpdateProgressText"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Visibility="Collapsed" />

        </StackPanel>
    </ScrollViewer>
</Page>
