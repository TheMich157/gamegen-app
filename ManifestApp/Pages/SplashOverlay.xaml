<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="ManifestApp.Pages.SplashOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="Root">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF0A0A12" Offset="0" />
                <GradientStop Color="#FF15101F" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Twinkling star field (populated in code-behind) -->
        <Canvas x:Name="StarsCanvas"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                IsHitTestVisible="False" />

        <!-- Pulsing nebula halo -->
        <Ellipse x:Name="Halo"
                 Width="860" Height="860"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 IsHitTestVisible="False"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.Fill>
                <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5"
                                     RadiusX="0.5" RadiusY="0.5">
                    <GradientStop Color="#806E45FF" Offset="0.0" />
                    <GradientStop Color="#403B6BFF" Offset="0.45" />
                    <GradientStop Color="#000A0A12" Offset="1.0" />
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.RenderTransform>
                <CompositeTransform x:Name="HaloXform" ScaleX="0.9" ScaleY="0.9" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Center stack -->
        <StackPanel x:Name="ContentPanel"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Spacing="26"
                    Opacity="0"
                    RenderTransformOrigin="0.5,0.5">
            <StackPanel.RenderTransform>
                <CompositeTransform x:Name="ContentXform" ScaleX="0.86" ScaleY="0.86" />
            </StackPanel.RenderTransform>

            <Grid Width="208" Height="208" HorizontalAlignment="Center">

                <!-- Soft glow behind logo -->
                <Ellipse x:Name="LogoGlow"
                         Width="170" Height="170"
                         IsHitTestVisible="False"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.Fill>
                        <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5"
                                             RadiusX="0.5" RadiusY="0.5">
                            <GradientStop Color="#A06E45FF" Offset="0.0" />
                            <GradientStop Color="#503B6BFF" Offset="0.5" />
                            <GradientStop Color="#000A0A12" Offset="1.0" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.RenderTransform>
                        <CompositeTransform x:Name="LogoGlowXform" ScaleX="0.95" ScaleY="0.95" />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- Outer dashed ring (slow CW) -->
                <Ellipse Width="208" Height="208"
                         Stroke="#506E45FF" StrokeThickness="1.5"
                         StrokeDashArray="2,4"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="Ring1Xform" Angle="0" />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- Middle ring with gradient stroke (fast CCW) -->
                <Ellipse Width="172" Height="172"
                         StrokeThickness="2"
                         StrokeDashArray="4,18"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.Stroke>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFB8C8FF" Offset="0" />
                            <GradientStop Color="#003B6BFF" Offset="1" />
                        </LinearGradientBrush>
                    </Ellipse.Stroke>
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="Ring2Xform" Angle="0" />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- Inner thin ring (medium CW) -->
                <Ellipse Width="142" Height="142"
                         Stroke="#80B8C8FF" StrokeThickness="1.2"
                         StrokeDashArray="1,3"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="Ring3Xform" Angle="0" />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- Logo plate -->
                <Border Width="100" Height="100"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        CornerRadius="22"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF6E45FF" Offset="0" />
                            <GradientStop Color="#FF3B6BFF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Image Source="ms-appx:///Assets/GameGenAppLogo.png"
                           Stretch="UniformToFill"
                           Margin="6" />
                    <Border.RenderTransform>
                        <CompositeTransform x:Name="LogoXform" ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                </Border>
            </Grid>

            <!-- Per-letter wordmark — staggered slide-up + fade-in -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="Letter0" Text="G" FontSize="36" FontWeight="SemiLight"
                           Foreground="#FFEDEDF5" CharacterSpacing="120" Opacity="0"
                           RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="Letter0Xform" Y="22" />
                    </TextBlock.RenderTransform>
                </TextBlock>
                <TextBlock x:Name="Letter1" Text="a" FontSize="36" FontWeight="SemiLight"
                           Foreground="#FFEDEDF5" CharacterSpacing="120" Opacity="0">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="Letter1Xform" Y="22" />
                    </TextBlock.RenderTransform>
                </TextBlock>
                <TextBlock x:Name="Letter2" Text="m" FontSize="36" FontWeight="SemiLight"
                           Foreground="#FFEDEDF5" CharacterSpacing="120" Opacity="0">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="Letter2Xform" Y="22" />
                    </TextBlock.RenderTransform>
                </TextBlock>
                <TextBlock x:Name="Letter3" Text="e" FontSize="36" FontWeight="SemiLight"
                           Foreground="#FFEDEDF5" CharacterSpacing="120" Opacity="0">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="Letter3Xform" Y="22" />
                    </TextBlock.RenderTransform>
                </TextBlock>
                <TextBlock x:Name="Letter4" Text="G" FontSize="36" FontWeight="SemiLight"
                           Foreground="#FFEDEDF5" CharacterSpacing="120" Opacity="0">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="Letter4Xform" Y="22" />
                    </TextBlock.RenderTransform>
                </TextBlock>
                <TextBlock x:Name="Letter5" Text="e" FontSize="36" FontWeight="SemiLight"
                           Foreground="#FFEDEDF5" CharacterSpacing="120" Opacity="0">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="Letter5Xform" Y="22" />
                    </TextBlock.RenderTransform>
                </TextBlock>
                <TextBlock x:Name="Letter6" Text="n" FontSize="36" FontWeight="SemiLight"
                           Foreground="#FFEDEDF5" CharacterSpacing="120" Opacity="0">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="Letter6Xform" Y="22" />
                    </TextBlock.RenderTransform>
                </TextBlock>
            </StackPanel>

            <TextBlock x:Name="VersionLine"
                       HorizontalAlignment="Center"
                       FontSize="11" Opacity="0.55"
                       Foreground="#FFAFAFC4"
                       CharacterSpacing="80" />

            <!-- Step list -->
            <StackPanel x:Name="StepsPanel" Spacing="10" HorizontalAlignment="Center"
                        Width="300" Margin="0,8,0,0">

                <Grid x:Name="Step0Row" Height="22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Width="20" Height="20" HorizontalAlignment="Center">
                        <Ellipse x:Name="Step0Pending" Width="14" Height="14"
                                 Stroke="#40B8C8FF" StrokeThickness="1.5" />
                        <ProgressRing x:Name="Step0Active" Width="16" Height="16"
                                      IsActive="False" Visibility="Collapsed"
                                      Foreground="#FFB8C8FF" />
                        <FontIcon x:Name="Step0Done" Glyph="&#xE73E;" FontSize="14"
                                  Foreground="#FF7DD3A0" Visibility="Collapsed" />
                    </Grid>
                    <TextBlock x:Name="Step0Text" Grid.Column="1"
                               Text="Checking for updates"
                               FontSize="13" Foreground="#66B8C8FF"
                               VerticalAlignment="Center" />
                </Grid>

                <Grid x:Name="Step1Row" Height="22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Width="20" Height="20" HorizontalAlignment="Center">
                        <Ellipse x:Name="Step1Pending" Width="14" Height="14"
                                 Stroke="#40B8C8FF" StrokeThickness="1.5" />
                        <ProgressRing x:Name="Step1Active" Width="16" Height="16"
                                      IsActive="False" Visibility="Collapsed"
                                      Foreground="#FFB8C8FF" />
                        <FontIcon x:Name="Step1Done" Glyph="&#xE73E;" FontSize="14"
                                  Foreground="#FF7DD3A0" Visibility="Collapsed" />
                    </Grid>
                    <TextBlock x:Name="Step1Text" Grid.Column="1"
                               Text="Preparing workspace"
                               FontSize="13" Foreground="#66B8C8FF"
                               VerticalAlignment="Center" />
                </Grid>

                <Grid x:Name="Step2Row" Height="22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Width="20" Height="20" HorizontalAlignment="Center">
                        <Ellipse x:Name="Step2Pending" Width="14" Height="14"
                                 Stroke="#40B8C8FF" StrokeThickness="1.5" />
                        <ProgressRing x:Name="Step2Active" Width="16" Height="16"
                                      IsActive="False" Visibility="Collapsed"
                                      Foreground="#FFB8C8FF" />
                        <FontIcon x:Name="Step2Done" Glyph="&#xE73E;" FontSize="14"
                                  Foreground="#FF7DD3A0" Visibility="Collapsed" />
                    </Grid>
                    <TextBlock x:Name="Step2Text" Grid.Column="1"
                               Text="Ready"
                               FontSize="13" Foreground="#66B8C8FF"
                               VerticalAlignment="Center" />
                </Grid>
            </StackPanel>
        </StackPanel>

        <Grid.Resources>
            <!-- Halo pulse -->
            <Storyboard x:Name="HaloLoop" RepeatBehavior="Forever" AutoReverse="True">
                <DoubleAnimation Storyboard.TargetName="HaloXform" Storyboard.TargetProperty="ScaleX"
                                 From="0.9" To="1.06" Duration="0:0:3.6">
                    <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="HaloXform" Storyboard.TargetProperty="ScaleY"
                                 From="0.9" To="1.06" Duration="0:0:3.6">
                    <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <!-- Logo glow pulse (slightly out of phase with logo breath) -->
            <Storyboard x:Name="LogoGlowLoop" RepeatBehavior="Forever" AutoReverse="True">
                <DoubleAnimation Storyboard.TargetName="LogoGlowXform" Storyboard.TargetProperty="ScaleX"
                                 From="0.95" To="1.18" Duration="0:0:2.4">
                    <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="LogoGlowXform" Storyboard.TargetProperty="ScaleY"
                                 From="0.95" To="1.18" Duration="0:0:2.4">
                    <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="LogoGlow" Storyboard.TargetProperty="Opacity"
                                 From="0.85" To="1.0" Duration="0:0:2.4">
                    <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <!-- Ring rotations -->
            <Storyboard x:Name="Ring1Loop" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="Ring1Xform" Storyboard.TargetProperty="Angle"
                                 From="0" To="360" Duration="0:0:18" />
            </Storyboard>
            <Storyboard x:Name="Ring2Loop" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="Ring2Xform" Storyboard.TargetProperty="Angle"
                                 From="360" To="0" Duration="0:0:9" />
            </Storyboard>
            <Storyboard x:Name="Ring3Loop" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="Ring3Xform" Storyboard.TargetProperty="Angle"
                                 From="0" To="360" Duration="0:0:6" />
            </Storyboard>

            <!-- Logo breathing -->
            <Storyboard x:Name="LogoBreath" RepeatBehavior="Forever" AutoReverse="True">
                <DoubleAnimation Storyboard.TargetName="LogoXform" Storyboard.TargetProperty="ScaleX"
                                 From="1.0" To="1.05" Duration="0:0:2.4">
                    <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="LogoXform" Storyboard.TargetProperty="ScaleY"
                                 From="1.0" To="1.05" Duration="0:0:2.4">
                    <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <!-- Intro: scale + fade content panel -->
            <Storyboard x:Name="ContentIntroSb">
                <DoubleAnimation Storyboard.TargetName="ContentPanel" Storyboard.TargetProperty="Opacity"
                                 From="0" To="1" Duration="0:0:0.55" />
                <DoubleAnimation Storyboard.TargetName="ContentXform" Storyboard.TargetProperty="ScaleX"
                                 From="0.86" To="1" Duration="0:0:0.7">
                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="ContentXform" Storyboard.TargetProperty="ScaleY"
                                 From="0.86" To="1" Duration="0:0:0.7">
                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <!-- Per-letter wordmark cascade (60ms stagger, slide up + fade) -->
            <Storyboard x:Name="WordmarkSb">
                <DoubleAnimation Storyboard.TargetName="Letter0" Storyboard.TargetProperty="Opacity"
                                 From="0" To="1" Duration="0:0:0.45" BeginTime="0:0:0.30" />
                <DoubleAnimation Storyboard.TargetName="Letter0Xform" Storyboard.TargetProperty="Y"
                                 From="22" To="0" Duration="0:0:0.5" BeginTime="0:0:0.30">
                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>

                <DoubleAnimation Storyboard.TargetName="Letter1" Storyboard.TargetProperty="Opacity"
                                 From="0" To="1" Duration="0:0:0.45" BeginTime="0:0:0.36" />
                <DoubleAnimation Storyboard.TargetName="Letter1Xform" Storyboard.TargetProperty="Y"
                                 From="22" To="0" Duration="0:0:0.5" BeginTime="0:0:0.36">
                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>

                <DoubleAnimation Storyboard.TargetName="Letter2" Storyboard.TargetProperty="Opacity"
                                 From="0" To="1" Duration="0:0:0.45" BeginTime="0:0:0.42" />
                <DoubleAnimation Storyboard.TargetName="Letter2Xform" Storyboard.TargetProperty="Y"
                                 From="22" To="0" Duration="0:0:0.5" BeginTime="0:0:0.42">
                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>

                <DoubleAnimation Storyboard.TargetName="Letter3" Storyboard.TargetProperty="Opacity"
                                 From="0" To="1" Duration="0:0:0.45" BeginTime="0:0:0.48" />
                <DoubleAnimation Storyboard.TargetName="Letter3Xform" Storyboard.TargetProperty="Y"
                                 From="22" To="0" Duration="0:0:0.5" BeginTime="0:0:0.48">
                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>

                <DoubleAnimation Storyboard.TargetName="Letter4" Storyboard.TargetProperty="Opacity"
                                 From="0" To="1" Duration="0:0:0.45" BeginTime="0:0:0.54" />
                <DoubleAnimation Storyboard.TargetName="Letter4Xform" Storyboard.TargetProperty="Y"
                                 From="22" To="0" Duration="0:0:0.5" BeginTime="0:0:0.54">
                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>

                <DoubleAnimation Storyboard.TargetName="Letter5" Storyboard.TargetProperty="Opacity"
                                 From="0" To="1" Duration="0:0:0.45" BeginTime="0:0:0.60" />
                <DoubleAnimation Storyboard.TargetName="Letter5Xform" Storyboard.TargetProperty="Y"
                                 From="22" To="0" Duration="0:0:0.5" BeginTime="0:0:0.60">
                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>

                <DoubleAnimation Storyboard.TargetName="Letter6" Storyboard.TargetProperty="Opacity"
                                 From="0" To="1" Duration="0:0:0.45" BeginTime="0:0:0.66" />
                <DoubleAnimation Storyboard.TargetName="Letter6Xform" Storyboard.TargetProperty="Y"
                                 From="22" To="0" Duration="0:0:0.5" BeginTime="0:0:0.66">
                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <!-- Outro: zoom + fade with halo flash -->
            <Storyboard x:Name="OutroSb">
                <DoubleAnimation Storyboard.TargetName="HaloXform" Storyboard.TargetProperty="ScaleX"
                                 To="1.4" Duration="0:0:0.55">
                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="HaloXform" Storyboard.TargetProperty="ScaleY"
                                 To="1.4" Duration="0:0:0.55">
                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="ContentXform" Storyboard.TargetProperty="ScaleX"
                                 To="1.18" Duration="0:0:0.5">
                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="ContentXform" Storyboard.TargetProperty="ScaleY"
                                 To="1.18" Duration="0:0:0.5">
                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                 To="0" Duration="0:0:0.45" BeginTime="0:0:0.15" />
            </Storyboard>
        </Grid.Resources>
    </Grid>
</UserControl>
