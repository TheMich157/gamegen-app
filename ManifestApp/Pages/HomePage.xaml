<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ManifestApp.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ManifestApp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Disabled"
    mc:Ignorable="d">

    <Page.Resources>
        <Storyboard x:Name="StatusPulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="StatusDot" Storyboard.TargetProperty="Opacity"
                             From="0.45" To="1.0" Duration="0:0:1.2">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Page.Resources>

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="F" Modifiers="Control" Invoked="FocusSearch_Accelerator" />
        <KeyboardAccelerator Key="F5" Invoked="Refresh_Accelerator" />
    </Page.KeyboardAccelerators>

    <Grid Padding="{StaticResource ManifestInsetPadding}" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ScrollViewer
            Grid.Row="0"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto"
            ZoomMode="Disabled">

            <StackPanel Spacing="16">

                <!-- ──────── HERO ──────── -->
                <Border CornerRadius="20" Padding="24,20,24,20"
                        BorderThickness="1" BorderBrush="#1FB8C8FF">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF120E20" Offset="0" />
                            <GradientStop Color="#FF1A0E2C" Offset="0.5" />
                            <GradientStop Color="#FF0F0E1F" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <StackPanel Spacing="12">

                        <!-- Status pill -->
                        <Border CornerRadius="999" Padding="10,4,14,4"
                                BorderThickness="1" BorderBrush="#506E45FF"
                                Background="#1F6E45FF"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Ellipse x:Name="StatusDot" Width="6" Height="6" Fill="#FF8B65FF" />
                                <TextBlock Text="MANIFEST HUB ACTIVE"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="#FFB8C8FF"
                                           CharacterSpacing="120" />
                            </StackPanel>
                        </Border>

                        <!-- Eyebrow + gradient title -->
                        <StackPanel Spacing="0">
                            <TextBlock Text="GAMEGEN"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="#809FB7FF"
                                       CharacterSpacing="200" />
                            <TextBlock FontSize="42" FontWeight="Bold"
                                       LineHeight="48" CharacterSpacing="-10"
                                       Text="MANIFEST HUB">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF8B65FF" Offset="0" />
                                        <GradientStop Color="#FF5B7FFF" Offset="1" />
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </StackPanel>

                        <!-- Description (HomeIntroText is rewritten by code-behind per source) -->
                        <TextBlock x:Name="HomeIntroText"
                                   Foreground="#C0EDEDF5"
                                   FontSize="12" LineHeight="18"
                                   MaxWidth="640"
                                   HorizontalAlignment="Left"
                                   TextWrapping="WrapWholeWords"
                                   Text="Search the Steam Store, browse what's installed locally, and deploy GameGen manifests to your Steam plugin and depotcache folders." />

                        <!-- CTA -->
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Click="SearchStore_Click"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Padding="16,8,16,8">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE721;" FontSize="12" />
                                    <TextBlock Text="SEARCH STORE" FontSize="12"
                                               FontWeight="SemiBold" CharacterSpacing="60" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Stats row -->
                        <Grid ColumnSpacing="32" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="0">
                                <TextBlock x:Name="StatTitlesValue"
                                           Text="50k+"
                                           FontSize="26" FontWeight="Bold" LineHeight="30">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FF8B65FF" Offset="0" />
                                            <GradientStop Color="#FF5B7FFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                </TextBlock>
                                <TextBlock Text="TITLES"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="#80AFAFC4"
                                           CharacterSpacing="160" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="0">
                                <TextBlock Text="STEAM"
                                           FontSize="26" FontWeight="Bold" LineHeight="30">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FF8B65FF" Offset="0" />
                                            <GradientStop Color="#FF5B7FFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                </TextBlock>
                                <TextBlock Text="STORE SYNC"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="#80AFAFC4"
                                           CharacterSpacing="160" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="0">
                                <TextBlock Text="GAMEGEN"
                                           FontSize="26" FontWeight="Bold" LineHeight="30">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FF8B65FF" Offset="0" />
                                            <GradientStop Color="#FF5B7FFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                </TextBlock>
                                <TextBlock Text="POWERED BY"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="#80AFAFC4"
                                           CharacterSpacing="160" />
                            </StackPanel>
                        </Grid>

                        <!-- Feature cards row -->
                        <Grid ColumnSpacing="8" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" CornerRadius="10" Padding="12,10,12,10"
                                    BorderThickness="1" BorderBrush="#306E45FF"
                                    Background="#106E45FF">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE721;" FontSize="16"
                                              Foreground="#FF8B65FF" VerticalAlignment="Center" />
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="STORE SEARCH"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="#FF8B65FF"
                                                   CharacterSpacing="100" />
                                        <TextBlock Text="Steam catalog lookup"
                                                   FontSize="10" Opacity="0.65"
                                                   Foreground="#FFEDEDF5" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" CornerRadius="10" Padding="12,10,12,10"
                                    BorderThickness="1" BorderBrush="#303B6BFF"
                                    Background="#103B6BFF">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE8AB;" FontSize="16"
                                              Foreground="#FF5B7FFF" VerticalAlignment="Center" />
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="INSTALLED"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="#FF5B7FFF"
                                                   CharacterSpacing="100" />
                                        <TextBlock Text="Local appmanifest scan"
                                                   FontSize="10" Opacity="0.65"
                                                   Foreground="#FFEDEDF5" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" CornerRadius="10" Padding="12,10,12,10"
                                    BorderThickness="1" BorderBrush="#307DD3A0"
                                    Background="#107DD3A0">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE8F1;" FontSize="16"
                                              Foreground="#FF7DD3A0" VerticalAlignment="Center" />
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="LIBRARY"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="#FF7DD3A0"
                                                   CharacterSpacing="100" />
                                        <TextBlock Text="Tracked manifests"
                                                   FontSize="10" Opacity="0.65"
                                                   Foreground="#FFEDEDF5" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ──────── STEAM PATH BANNER ──────── -->
                <InfoBar
                    x:Name="SteamPathBanner"
                    CornerRadius="{StaticResource ControlCornerRadius}"
                    IsClosable="False"
                    IsOpen="True"
                    Message="Steam install path not detected. Set it in Settings so manifests can deploy to plugin/depotcache folders."
                    Severity="Informational"
                    Visibility="Collapsed" />

                <!-- ──────── SOURCE / SEARCH CARD ──────── -->
                <Border
                    Padding="16,12,16,12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource ManifestCardCornerRadius}">
                    <StackPanel Spacing="8">
                        <TextBlock
                            FontSize="12" FontWeight="SemiBold"
                            CharacterSpacing="160"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="SOURCE" />

                        <ComboBox
                            x:Name="SourceCombo"
                            HorizontalAlignment="Stretch"
                            Header="Games list source"
                            SelectionChanged="SourceCombo_SelectionChanged">

                            <ComboBoxItem Tag="store">
                                <StackPanel MinHeight="26" Orientation="Horizontal" Spacing="8">
                                    <FontIcon Margin="0,2,0,0" VerticalAlignment="Center"
                                              FontSize="14" Glyph="&#xE721;" />
                                    <TextBlock VerticalAlignment="Center" FontSize="12"
                                               Text="Steam Store search (name → storefront App ID)"
                                               TextWrapping="NoWrap" />
                                </StackPanel>
                            </ComboBoxItem>

                            <ComboBoxItem Tag="installed">
                                <StackPanel MinHeight="26" Orientation="Horizontal" Spacing="8">
                                    <FontIcon Margin="0,2,0,0" VerticalAlignment="Center"
                                              FontSize="14" Glyph="&#xE8AB;" />
                                    <TextBlock VerticalAlignment="Center" FontSize="12"
                                               Text="Installed Steam games on this PC (appmanifest *.acf)"
                                               TextWrapping="NoWrap" />
                                </StackPanel>
                            </ComboBoxItem>

                            <ComboBoxItem Tag="library">
                                <StackPanel MinHeight="26" Orientation="Horizontal" Spacing="8">
                                    <FontIcon Margin="0,2,0,0" VerticalAlignment="Center"
                                              FontSize="14" Glyph="&#xE8F1;" />
                                    <TextBlock VerticalAlignment="Center" FontSize="12"
                                               Text="Manifest library (installed via this app, for removal)"
                                               TextWrapping="NoWrap" />
                                </StackPanel>
                            </ComboBoxItem>
                        </ComboBox>

                        <StackPanel Spacing="8">
                            <AutoSuggestBox
                                x:Name="SearchBox"
                                HorizontalAlignment="Stretch"
                                PlaceholderText="Search Steam Store…"
                                QuerySubmitted="SearchBox_QuerySubmitted" />

                            <Button
                                x:Name="RefreshInstalledButton"
                                MinWidth="120"
                                Padding="16,8,16,8"
                                HorizontalAlignment="Left"
                                Click="RefreshInstalled_Click"
                                Content="Refresh list"
                                Visibility="Collapsed" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1" Margin="0,4,0,0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <GridView
                x:Name="GamesGrid"
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                MinHeight="200"
                IsItemClickEnabled="False"
                SelectionMode="Single"
                SelectionChanged="GamesGrid_SelectionChanged">

                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="Margin" Value="0,0,12,14" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="MinWidth" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </GridView.ItemContainerStyle>

                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="local:GameRowVm">
                        <Border
                            Width="200"
                            Margin="0,0,0,0"
                            Padding="8,8,8,10"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource ManifestCardCornerRadius}">
                            <StackPanel Spacing="8">

                                <Border Height="90" CornerRadius="8"
                                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                                    <Grid>
                                        <Image Stretch="UniformToFill">
                                            <Image.Source>
                                                <BitmapImage UriSource="{x:Bind ThumbUri}" />
                                            </Image.Source>
                                        </Image>

                                        <Border
                                            Margin="8"
                                            Padding="7,3,7,4"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            CornerRadius="{StaticResource ControlCornerRadius}"
                                            Visibility="{x:Bind IsConfigured, Converter={StaticResource ManifestBoolToVisibility}}">
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                Text="Tracked" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="{x:Bind DisplayName}"
                                    MaxLines="3"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="WrapWholeWords" />

                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind AppIdFormatted}" />

                                <TextBlock
                                    MaxLines="2"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Text="{x:Bind TrackingSubtitleLine}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="WrapWholeWords"
                                    Visibility="{x:Bind TrackingSubtitleLine, Converter={StaticResource ManifestNonEmptyToVisibility}}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <Border
                x:Name="DetailPanel"
                Grid.Column="1"
                MinWidth="280"
                MaxWidth="340"
                Width="320"
                VerticalAlignment="Stretch"
                Padding="16,14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource ManifestCardCornerRadius}"
                Visibility="Collapsed">

                <ScrollViewer
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    ZoomMode="Disabled">

                    <StackPanel Spacing="10">
                        <StackPanel Spacing="4">
                            <TextBlock
                                FontSize="12" FontWeight="SemiBold"
                                CharacterSpacing="160"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="DETAILS" />
                            <TextBlock
                                x:Name="DetailTitle"
                                FontSize="18"
                                FontWeight="SemiBold"
                                TextTrimming="CharacterEllipsis"
                                MaxLines="2"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <TextBlock
                            x:Name="DetailStatus"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            LineHeight="20"
                            FontSize="13"
                            TextWrapping="WrapWholeWords" />

                        <Grid x:Name="DetailActionsRow" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button
                                x:Name="InstallButton"
                                Grid.Column="0"
                                HorizontalAlignment="Stretch" MinHeight="40"
                                Click="Install_Click"
                                Content="Install manifests"
                                Style="{StaticResource AccentButtonStyle}" />
                            <Button
                                x:Name="RemoveButton"
                                Grid.Column="1"
                                HorizontalAlignment="Stretch" MinHeight="40"
                                Click="Remove_Click"
                                Content="Remove files" />
                        </Grid>

                        <Button
                            x:Name="LaunchSteamButton"
                            HorizontalAlignment="Stretch" MinHeight="40"
                            Click="LaunchSteam_Click"
                            Content="Launch in Steam"
                            Visibility="Collapsed" />

                        <!-- Steam client actions — install / uninstall the actual game via Steam. -->
                        <StackPanel x:Name="SteamActionsPanel" Spacing="6" Visibility="Collapsed">
                            <TextBlock Text="STEAM CLIENT"
                                       FontSize="11" FontWeight="SemiBold"
                                       CharacterSpacing="200"
                                       Foreground="{StaticResource GameGenAccentGradientBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="SteamInstallButton"
                                        MinWidth="140" MinHeight="36"
                                        Click="SteamInstall_Click"
                                        Content="Install via Steam" />
                                <Button x:Name="SteamUninstallButton"
                                        MinWidth="130" MinHeight="36"
                                        Click="SteamUninstall_Click"
                                        Content="Uninstall via Steam" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="InstallProgressPanel" Spacing="6" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <ProgressRing
                                    x:Name="InstallProgressRing"
                                    Width="20" Height="20"
                                    IsActive="False"
                                    Visibility="Collapsed" />
                                <ProgressBar
                                    x:Name="InstallProgressBar"
                                    Width="180"
                                    Maximum="100"
                                    Value="0"
                                    Visibility="Collapsed" />
                            </StackPanel>
                            <TextBlock
                                x:Name="InstallProgressText"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>

                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4,0,0" />

                        <StackPanel Spacing="2">
                            <TextBlock Text="FOLDERS"
                                       FontSize="10" FontWeight="SemiBold"
                                       CharacterSpacing="160"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="0" Margin="-8,0,0,0">
                                <HyperlinkButton Click="OpenPluginFolder_Click" Padding="8,6,8,6">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon Glyph="&#xE8B7;" FontSize="12" />
                                        <TextBlock Text="stplug-in" FontSize="12" />
                                    </StackPanel>
                                </HyperlinkButton>
                                <HyperlinkButton Click="OpenDepotFolder_Click" Padding="8,6,8,6">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon Glyph="&#xE8B7;" FontSize="12" />
                                        <TextBlock Text="depotcache" FontSize="12" />
                                    </StackPanel>
                                </HyperlinkButton>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
