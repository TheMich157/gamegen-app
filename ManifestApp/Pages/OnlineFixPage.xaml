<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ManifestApp.Pages.OnlineFixPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ManifestApp"
    xmlns:models="using:ManifestApp.Core.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Disabled"
    mc:Ignorable="d">

    <Grid Padding="{StaticResource ManifestInsetPadding}" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ──────── HERO ──────── -->
        <Border Grid.Row="0" CornerRadius="20" Padding="24,20,24,20"
                BorderThickness="1" BorderBrush="#1F00F2FE">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF0A091A" Offset="0" />
                    <GradientStop Color="#FF0B152B" Offset="0.5" />
                    <GradientStop Color="#FF070714" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <StackPanel Spacing="12">

                <!-- Status pill -->
                <Border CornerRadius="0" Padding="10,4,14,4"
                        BorderThickness="1" BorderBrush="#5000F2FE"
                        Background="#1F00F2FE"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE774;" FontSize="10" Foreground="#FF00F2FE" />
                        <TextBlock Text="MULTIPLAYER FIXES"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="#FF00F2FE"
                                   CharacterSpacing="120" />
                    </StackPanel>
                </Border>

                <!-- Title -->
                <StackPanel Spacing="0">
                    <TextBlock Text="GAMEGEN"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#809FB7FF"
                               CharacterSpacing="200" />
                    <TextBlock FontSize="42" FontWeight="Bold"
                               LineHeight="48" CharacterSpacing="-10"
                               Text="ONLINE FIXES">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF00F2FE" Offset="0" />
                                <GradientStop Color="#FF4FACFE" Offset="1" />
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                </StackPanel>

                <TextBlock
                    Foreground="#C0EDEDF5"
                    FontSize="12" LineHeight="18"
                    MaxWidth="640"
                    HorizontalAlignment="Left"
                    TextWrapping="WrapWholeWords"
                    Text="Directly search and download multiplayer fixes from the OnlineFix database by game name. All files are loaded directly upon verification of your API key." />

                <!-- Info Row / Chips -->
                <Grid ColumnSpacing="8" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="10" Padding="12,8,12,8"
                            BorderThickness="1" BorderBrush="#3000F2FE" Background="#1000F2FE">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE721;" FontSize="14" Foreground="#FF00F2FE" />
                            <StackPanel>
                                <TextBlock Text="SEARCH DATABASE" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#FF00F2FE" CharacterSpacing="100" />
                                <TextBlock Text="Find multiplayer fixes" FontSize="10" Opacity="0.65"
                                           Foreground="#FFEDEDF5" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" CornerRadius="10" Padding="12,8,12,8"
                            BorderThickness="1" BorderBrush="#304FACFE" Background="#104FACFE">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE896;" FontSize="14" Foreground="#FF4FACFE" />
                            <StackPanel>
                                <TextBlock Text="DIRECT DOWNLOAD" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#FF4FACFE" CharacterSpacing="100" />
                                <TextBlock Text="One-click ZIP download" FontSize="10" Opacity="0.65"
                                           Foreground="#FFEDEDF5" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ──────── SEARCH CARD ──────── -->
        <Border Grid.Row="1"
                Padding="16,12,16,12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource ManifestCardCornerRadius}">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <Grid.ColumnDefinition Width="*" />
                    <Grid.ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <AutoSuggestBox
                    x:Name="SearchBox"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    PlaceholderText="Search fixes by game name (e.g. Palworld)..."
                    QueryIcon="Find"
                    TextChanged="SearchBox_TextChanged" />
                
                <Button
                    x:Name="RefreshButton"
                    Grid.Column="1"
                    MinHeight="32"
                    Padding="14,6"
                    Click="RefreshButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <FontIcon FontSize="12" Glyph="&#xE72C;" />
                        <TextBlock Text="Refresh List" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ──────── CONTENT PANEL ──────── -->
        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Loading overlay or list -->
            <Grid Grid.Column="0">
                <ProgressRing x:Name="LoadingRing" Width="48" Height="48" VerticalAlignment="Center" HorizontalAlignment="Center" IsActive="False" Visibility="Collapsed"/>
                
                <TextBlock x:Name="NoFixesText" Text="No fixes found or API key not verified." FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed" />

                <!-- Grid of Fixes -->
                <GridView
                    x:Name="FixesGrid"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    IsItemClickEnabled="False"
                    SelectionMode="Single"
                    SelectionChanged="FixesGrid_SelectionChanged">

                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Margin" Value="0,0,12,14" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="MinWidth" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </GridView.ItemContainerStyle>

                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:OnlineFixItem">
                            <Border
                                Width="210"
                                Padding="12"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource ManifestCardCornerRadius}">
                                <StackPanel Spacing="8">
                                    <Border Height="60" CornerRadius="6" Background="#1500F2FE">
                                        <FontIcon Glyph="&#xE774;" FontSize="28" Foreground="#FF00F2FE" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Border>
                                    
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}"
                                               MaxLines="2" TextTrimming="CharacterEllipsis"
                                               TextWrapping="WrapWholeWords" FontSize="13" Height="38"/>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,2,0,0">
                                        <TextBlock FontSize="10"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Text="{x:Bind Name}" 
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="110"/>
                                        <TextBlock FontSize="10"
                                                   Foreground="#FF4FACFE"
                                                   Text="{x:Bind Version}" 
                                                   Visibility="{x:Bind Version, Converter={StaticResource ManifestNonEmptyToVisibility}}"/>
                                    </StackPanel>

                                    <TextBlock FontSize="10"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               Text="{x:Bind Size}"
                                               Visibility="{x:Bind Size, Converter={StaticResource ManifestNonEmptyToVisibility}}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </Grid>

            <!-- Right Detail Panel -->
            <Border
                x:Name="DetailPanel"
                Grid.Column="1"
                MinWidth="280" MaxWidth="340" Width="320"
                VerticalAlignment="Stretch"
                Padding="16,14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource ManifestCardCornerRadius}"
                Visibility="Collapsed">

                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              ZoomMode="Disabled">
                    <StackPanel Spacing="14">

                        <StackPanel Spacing="4">
                            <TextBlock FontSize="12" FontWeight="SemiBold"
                                       CharacterSpacing="160"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="ONLINE FIX DETAILS" />
                            <TextBlock x:Name="DetailTitle"
                                       FontSize="18" FontWeight="SemiBold"
                                       TextWrapping="WrapWholeWords" />
                            <TextBlock x:Name="DetailName"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>

                        <!-- Properties List -->
                        <StackPanel Spacing="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Version:" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock x:Name="DetailVersionText" Grid.Column="1" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <Grid.ColumnDefinition Width="Auto" />
                                    <Grid.ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Size:" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock x:Name="DetailSizeText" Grid.Column="1" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" />
                            </Grid>
                        </StackPanel>

                        <TextBlock
                            FontSize="12"
                            TextWrapping="WrapWholeWords"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="This will download the multiplayer fix directly from the OnlineFix database as a ZIP archive. You will be prompted to select where to save the file." />

                        <Button
                            x:Name="DownloadButton"
                            HorizontalAlignment="Stretch"
                            MinHeight="42"
                            Click="DownloadButton_Click"
                            Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE896;" FontSize="13" />
                                <TextBlock Text="DOWNLOAD ZIP"
                                           FontSize="12" FontWeight="SemiBold"
                                           CharacterSpacing="60" />
                            </StackPanel>
                        </Button>

                        <!-- Progress Display -->
                        <StackPanel x:Name="DownloadProgressPanel" Spacing="6" Visibility="Collapsed">
                            <ProgressBar x:Name="DownloadProgressBar" Minimum="0" Maximum="100" Value="0" Height="4" />
                            <TextBlock x:Name="DownloadProgressText" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                        </StackPanel>

                        <InfoBar
                            x:Name="StatusInfoBar"
                            IsClosable="True"
                            IsOpen="False"
                            CornerRadius="{StaticResource ControlCornerRadius}" />

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
