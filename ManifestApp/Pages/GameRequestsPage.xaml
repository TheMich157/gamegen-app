<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ManifestApp.Pages.GameRequestsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ManifestApp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Disabled"
    mc:Ignorable="d">

    <Grid Padding="{StaticResource ManifestInsetPadding}" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ──────── HERO ──────── -->
        <Border Grid.Row="0" CornerRadius="20" Padding="24,20,24,20"
                BorderThickness="1" BorderBrush="#1FFB8C5F">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF120E20" Offset="0" />
                    <GradientStop Color="#FF1A100C" Offset="0.5" />
                    <GradientStop Color="#FF0F0E1F" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <StackPanel Spacing="12">

                <!-- Status pill -->
                <Border CornerRadius="999" Padding="10,4,14,4"
                        BorderThickness="1" BorderBrush="#50C87941"
                        Background="#1FC87941"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE715;" FontSize="10" Foreground="#FFFB8C5F" />
                        <TextBlock Text="FULFILLMENT PIPELINE"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="#FFFB8C5F"
                                   CharacterSpacing="120" />
                    </StackPanel>
                </Border>

                <!-- Title -->
                <StackPanel Spacing="0">
                    <TextBlock Text="GAMEGEN"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#809FB7FF"
                               CharacterSpacing="200" />
                    <TextBlock FontSize="42" FontWeight="Bold"
                               LineHeight="48" CharacterSpacing="-10"
                               Text="GAME REQUESTS">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FFFB8C5F" Offset="0" />
                                <GradientStop Color="#FFFF6B35" Offset="1" />
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                </StackPanel>

                <TextBlock
                    Foreground="#C0EDEDF5"
                    FontSize="12" LineHeight="18"
                    MaxWidth="640"
                    HorizontalAlignment="Left"
                    TextWrapping="WrapWholeWords"
                    Text="Can't find a game in GameGen? Search below and send a formal request. Requested titles are monitored by our fulfillment pipeline and prioritized for addition to the registry." />

                <!-- Feature chips -->
                <Grid ColumnSpacing="8" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="10" Padding="12,8,12,8"
                            BorderThickness="1" BorderBrush="#30FB8C5F" Background="#10FB8C5F">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE721;" FontSize="14" Foreground="#FFFB8C5F" />
                            <StackPanel>
                                <TextBlock Text="SEARCH" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#FFFB8C5F" CharacterSpacing="100" />
                                <TextBlock Text="Find any Steam game" FontSize="10" Opacity="0.65"
                                           Foreground="#FFEDEDF5" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" CornerRadius="10" Padding="12,8,12,8"
                            BorderThickness="1" BorderBrush="#30FF9B42" Background="#10FF9B42">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE715;" FontSize="14" Foreground="#FFFF9B42" />
                            <StackPanel>
                                <TextBlock Text="REQUEST" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#FFFF9B42" CharacterSpacing="100" />
                                <TextBlock Text="Submit to pipeline" FontSize="10" Opacity="0.65"
                                           Foreground="#FFEDEDF5" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" CornerRadius="10" Padding="12,8,12,8"
                            BorderThickness="1" BorderBrush="#307DD3A0" Background="#107DD3A0">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE9D9;" FontSize="14" Foreground="#FF7DD3A0" />
                            <StackPanel>
                                <TextBlock Text="TRACKED" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#FF7DD3A0" CharacterSpacing="100" />
                                <TextBlock Text="Monitored by team" FontSize="10" Opacity="0.65"
                                           Foreground="#FFEDEDF5" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ──────── SEARCH CARD ──────── -->
        <Border Grid.Row="1"
                Padding="16,12,16,12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource ManifestCardCornerRadius}">
            <StackPanel Spacing="8">
                <TextBlock FontSize="12" FontWeight="SemiBold"
                           CharacterSpacing="160"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="FIND A GAME TO REQUEST" />
                <AutoSuggestBox
                    x:Name="RequestSearchBox"
                    HorizontalAlignment="Stretch"
                    PlaceholderText="Search Steam Store or enter an App ID…"
                    QuerySubmitted="RequestSearch_QuerySubmitted" />
                <TextBlock
                    x:Name="SearchStatusText"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Visibility="Collapsed" />
            </StackPanel>
        </Border>

        <!-- ──────── RESULTS + REQUEST PANEL ──────── -->
        <Grid Grid.Row="2" Margin="0,4,0,0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Game grid -->
            <GridView
                x:Name="RequestGamesGrid"
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                MinHeight="200"
                IsItemClickEnabled="False"
                SelectionMode="Single"
                SelectionChanged="RequestGamesGrid_SelectionChanged">

                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="Margin" Value="0,0,12,14" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="MinWidth" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </GridView.ItemContainerStyle>

                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="local:GameRowVm">
                        <Border
                            Width="200"
                            Padding="8,8,8,10"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource ManifestCardCornerRadius}">
                            <StackPanel Spacing="8">
                                <Border Height="90" CornerRadius="8"
                                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                                    <Image Stretch="UniformToFill">
                                        <Image.Source>
                                            <BitmapImage UriSource="{x:Bind ThumbUri}" />
                                        </Image.Source>
                                    </Image>
                                </Border>
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind DisplayName}"
                                           MaxLines="3" TextTrimming="CharacterEllipsis"
                                           TextWrapping="WrapWholeWords" />
                                <TextBlock FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Text="{x:Bind AppIdFormatted}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <!-- Request detail / submit panel -->
            <Border
                x:Name="RequestDetailPanel"
                Grid.Column="1"
                MinWidth="280" MaxWidth="340" Width="320"
                VerticalAlignment="Stretch"
                Padding="16,14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource ManifestCardCornerRadius}"
                Visibility="Collapsed">

                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              ZoomMode="Disabled">
                    <StackPanel Spacing="12">

                        <StackPanel Spacing="4">
                            <TextBlock FontSize="12" FontWeight="SemiBold"
                                       CharacterSpacing="160"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="SEND REQUEST" />
                            <TextBlock x:Name="RequestDetailTitle"
                                       FontSize="18" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="2" TextWrapping="WrapWholeWords" />
                            <TextBlock x:Name="RequestDetailAppId"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>

                        <TextBlock
                            FontSize="12"
                            TextWrapping="WrapWholeWords"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="This submits a formal request to the GameGen fulfillment pipeline. Your request is monitored and the game will be prioritized for addition." />

                        <StackPanel Spacing="6">
                            <TextBlock Text="REASON (OPTIONAL)"
                                       FontSize="11" FontWeight="SemiBold"
                                       CharacterSpacing="120"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBox
                                x:Name="ReasonBox"
                                PlaceholderText="e.g. New update released, can't install via Steam…"
                                AcceptsReturn="False"
                                MaxLength="200"
                                TextWrapping="Wrap"
                                Height="68" />
                        </StackPanel>

                        <Button
                            x:Name="SendRequestButton"
                            HorizontalAlignment="Stretch"
                            MinHeight="42"
                            Click="SendRequest_Click"
                            Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE715;" FontSize="13" />
                                <TextBlock Text="SEND REQUEST"
                                           FontSize="12" FontWeight="SemiBold"
                                           CharacterSpacing="60" />
                            </StackPanel>
                        </Button>

                        <InfoBar
                            x:Name="RequestResultBar"
                            IsClosable="True"
                            IsOpen="False"
                            CornerRadius="{StaticResource ControlCornerRadius}" />

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
