<UserControl
    x:Class="ManifestApp.Pages.LockoutOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="Root">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF1A0505" Offset="0" />
                <GradientStop Color="#FF000000" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24">
            <Grid Width="120" Height="120" HorizontalAlignment="Center">
                <Ellipse Fill="#30FF0000" />
                <FontIcon Glyph="&#xE7BA;" FontSize="64" Foreground="#FFFF4444" />
            </Grid>

            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <TextBlock Text="ACCESS REVOKED" FontSize="32" FontWeight="Bold" 
                           Foreground="#FFFF4444" HorizontalAlignment="Center" CharacterSpacing="100" />
                <TextBlock Text="This API key has been disabled by an administrator." 
                           FontSize="16" Foreground="#80FFFFFF" HorizontalAlignment="Center" />
            </StackPanel>

            <Border Background="#10FFFFFF" CornerRadius="8" Padding="20,16" MaxWidth="400">
                <TextBlock Text="If you believe this is an error, please contact support on Discord. Your session has been terminated to protect system integrity." 
                           FontSize="13" Foreground="#60FFFFFF" TextWrapping="Wrap" TextAlignment="Center" />
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
